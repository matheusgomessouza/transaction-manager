{
  "name": "transaction-manager-monorepo",
  "private": true,
  "packageManager": "npm@10.11.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "node -e \"if(process.env.CI!=='true')process.exit(1)\" || husky"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "fast-check": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "pure-rand": "^8.4.0",
    "turbo": "^1.13.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.27.4",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0"
  }
}
