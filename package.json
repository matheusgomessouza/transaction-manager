{
  "name": "transaction-manager-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "eslint": "^8.57.0",
    "fast-check": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "pure-rand": "^8.4.0",
    "turbo": "^1.13.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.27.4",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0"
  }
}
